# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Resend (email delivery)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=rezm.ai <noreply@rezm.ai>
EMAIL_DOMAIN=resmail.ai

# Supabase Access Token (for auto-migrations — from supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_your-access-token

# Supabase Auth Hook (for custom auth emails)
AUTH_HOOK_SECRET=your-hook-secret-here

# Inbound Email Webhook
EMAIL_WEBHOOK_SECRET=your-webhook-secret-here

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_PREMIUM_PRICE_ID=price_your-premium-price-id

# Twilio (phone system)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_COUNTRY=US
TWILIO_CALLER_ID=

# Claude API (AI resume review)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Cloudflare Turnstile (optional, for contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Vercel Domains API (for custom domain feature)
# Token: https://vercel.com/account/tokens
# Project ID: Project Settings -> General -> Project ID
# Team ID: Only needed for team projects
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
