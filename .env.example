# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Resend (email delivery)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=ResumeProfile <noreply@resumeprofile.com>
EMAIL_DOMAIN=resumeprofile.com

# Supabase Auth Hook (for custom auth emails)
AUTH_HOOK_SECRET=your-hook-secret-here

# Inbound Email Webhook
EMAIL_WEBHOOK_SECRET=your-webhook-secret-here

# Cloudflare Turnstile (optional, for contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
